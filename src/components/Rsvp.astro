---
interface Props {
  title: string;
  subtitle: string;
  intro: string;
  google_form_url: string;
  deadline: string;
}
const { title, subtitle, intro, google_form_url, deadline } = Astro.props;

const isPlaceholder = google_form_url.includes('PLACEHOLDER');
---

<section class="section">
  <div class="container rsvp-container">
    <h2 class="section-title">{title}</h2>
    <p class="section-subtitle">{subtitle}</p>
    <div class="divider"></div>
    <p class="rsvp-intro">{intro}</p>
    <p class="rsvp-deadline">{deadline}</p>

    {isPlaceholder ? (
      <div class="form-placeholder">
        <p>Google Form not yet configured.<br />
        Edit <code>src/data/[lang]/rsvp.yaml</code> and paste your Google Form embed URL.</p>
      </div>
    ) : (
      <div class="form-wrapper">
        <iframe
          src={google_form_url}
          width="100%"
          height="800"
          frameborder="0"
          marginheight="0"
          marginwidth="0"
          title="RSVP Form"
          loading="lazy"
        >Loading…</iframe>
      </div>
    )}
  </div>
</section>

<style>
  .rsvp-container {
    max-width: 700px;
  }

  .rsvp-intro {
    color: var(--color-muted);
    margin-bottom: var(--space-xs);
  }

  .rsvp-deadline {
    font-size: var(--size-sm);
    color: var(--color-accent);
    margin-bottom: var(--space-lg);
    font-style: italic;
  }

  .form-wrapper {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .form-placeholder {
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-xl);
    text-align: center;
    color: var(--color-muted);
  }

  .form-placeholder code {
    background: var(--color-surface);
    padding: 0.1em 0.4em;
    border-radius: var(--radius-sm);
    font-size: var(--size-sm);
  }
</style>
