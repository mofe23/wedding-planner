---
interface Props {
  lang: 'en' | 'de';
}
const { lang } = Astro.props;

const text = {
  en: 'Made with love',
  de: 'Mit Liebe gemacht',
};
---

<footer class="site-footer">
  <div class="container">
    <span class="footer-text">{text[lang]} &#9825;</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-lg);
    text-align: center;
  }

  .footer-text {
    font-family: var(--font-heading);
    font-style: italic;
    color: var(--color-muted);
    font-size: var(--size-sm);
  }
</style>
