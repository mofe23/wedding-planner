---
interface Props {
  title: string;
  subtitle: string;
  venue_name: string;
  address: string;
  maps_url: string;
  description: string;
  travel_notes: string;
  lang: 'en' | 'de';
}
const { title, subtitle, venue_name, address, maps_url, description, travel_notes, lang } = Astro.props;
const mapLabel = lang === 'en' ? 'Open in Google Maps' : 'In Google Maps öffnen';
const travelTitle = lang === 'en' ? 'Getting there' : 'Anreise';
---

<section class="section">
  <div class="container">
    <h2 class="section-title">{title}</h2>
    <p class="section-subtitle">{subtitle}</p>
    <div class="divider"></div>

    <div class="venue-grid">
      <div class="venue-info">
        <h3 class="venue-name">{venue_name}</h3>
        <p class="venue-address">{address}</p>
        <a href={maps_url} target="_blank" rel="noopener noreferrer" class="maps-link">
          {mapLabel} &rarr;
        </a>
        <p class="venue-desc">{description}</p>
      </div>

      <div class="travel-info">
        <h3 class="travel-title">{travelTitle}</h3>
        <p class="travel-notes">{travel_notes}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .venue-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    max-width: 800px;
  }

  .venue-name {
    font-size: var(--size-xl);
    margin-bottom: var(--space-xs);
  }

  .venue-address {
    color: var(--color-muted);
    margin-bottom: var(--space-sm);
  }

  .maps-link {
    display: inline-block;
    font-size: var(--size-sm);
    letter-spacing: 0.05em;
    margin-bottom: var(--space-md);
  }

  .venue-desc {
    color: var(--color-muted);
  }

  .travel-title {
    font-size: var(--size-xl);
    margin-bottom: var(--space-sm);
  }

  .travel-notes {
    color: var(--color-muted);
  }

  @media (max-width: 640px) {
    .venue-grid { grid-template-columns: 1fr; }
  }
</style>
